# Copy this file to .env and fill in your values.
# Required for Prisma and the app to connect to PostgreSQL.

# PostgreSQL connection string.
# Examples:
#   Local:  postgresql://postgres:postgres@localhost:5432/kudos
#   Neon:   postgresql://user:pass@host.neon.tech/neondb?sslmode=require
#   Vercel: from Vercel Postgres dashboard
DATABASE_URL=""

# Session signing secret (min 32 characters). Used to sign the "I am" session cookie.
# Generate with: openssl rand -base64 32
SESSION_SECRET="change-me-to-a-long-random-string-at-least-32-chars"

